= form_with model: doctor do |form|
  - if doctor.errors.any?
    %ul
      - doctor.errors.full_messages.each do |message|
        %li= message

  %div 
    = form.label :name
    = form.text_field :name
  
  %div
    = form.label :specialization
    = form.text_field :specialization

  %div
  = form.label :hospital_id, "Hospital"
  = form.collection_select :hospital_id,
                           Hospital.all,
                           :id,
                           :name,
                           prompt: "Select Hospital"

  %div
    = form.submit
